---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | Nadia`} description={post.data.description}>
  <article class="container post-article">

    <!-- ── Post header ─────────────────── -->
    <header class="post-header">
      <a href={`${import.meta.env.BASE_URL}blog`} class="breadcrumb">← All posts</a>
      <time class="post-date">
        {post.data.pubDate.toLocaleDateString("en-US", { dateStyle: "long" })}
      </time>
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-lead">{post.data.description}</p>
    </header>

    <!-- ── Post body ───────────────────── -->
    <div class="prose">
      <Content />
    </div>

    <!-- ── Post footer ─────────────────── -->
    <footer class="post-footer">
      <a href={`${import.meta.env.BASE_URL}blog`} class="btn btn-ghost">← Back to blog</a>
    </footer>

  </article>
</Layout>

<style>
  .post-article {
    padding-top: 3rem;
    padding-bottom: 4rem;
    max-width: 720px;
  }

  /* ── Header ──────────────────────────── */
  .post-header {
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--border);
    margin-bottom: 2.5rem;
  }

  .breadcrumb {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--muted) !important;
    margin-bottom: 1.25rem;
    transition: color var(--ease);
  }

  .breadcrumb:hover {
    color: var(--cucumber) !important;
  }

  .post-date {
    display: block;
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.8rem;
  }

  .post-title {
    font-size: clamp(1.85rem, 4.5vw, 2.75rem);
    margin-bottom: 1rem;
  }

  .post-lead {
    font-size: 1.15rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.75;
    border-left: 4px solid var(--banana);
    padding-left: 1rem;
  }

  /* ── Prose ───────────────────────────── */
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(p) {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text);
    margin-bottom: 1.35rem;
  }

  .prose :global(a) {
    color: var(--cucumber);
    font-weight: 700;
    border-bottom: 2px solid var(--cucumber-light);
    text-decoration: none;
    transition: border-color var(--ease), color var(--ease);
  }

  .prose :global(a:hover) {
    color: var(--caramel);
    border-color: var(--caramel);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.35rem;
  }

  .prose :global(li) {
    font-size: 1.05rem;
    line-height: 1.75;
    margin-bottom: 0.4rem;
    color: var(--text);
  }

  .prose :global(blockquote) {
    margin: 1.75rem 0;
    border-left: 4px solid var(--banana);
    background: var(--wheat);
    padding: 1rem 1.25rem;
    border-radius: 0 var(--radius) var(--radius) 0;
    font-style: italic;
    color: var(--muted);
  }

  .prose :global(blockquote p) {
    margin: 0;
  }

  .prose :global(code) {
    background: var(--wheat);
    color: var(--caramel);
    padding: 0.15em 0.4em;
    border-radius: 0.3em;
    font-size: 0.875em;
    font-family: ui-monospace, "Cascadia Code", "Source Code Pro", Menlo, monospace;
  }

  .prose :global(pre) {
    background: var(--coconut);
    color: #faf9f7;
    padding: 1.35rem 1.5rem;
    border-radius: var(--radius-lg);
    overflow-x: auto;
    margin-bottom: 1.75rem;
    border: 1.5px solid var(--coconut-soft);
  }

  .prose :global(pre code) {
    background: none;
    color: inherit;
    padding: 0;
    font-size: 0.875rem;
  }

  .prose :global(hr) {
    border: none;
    border-top: 2px solid var(--border);
    margin: 2.5rem 0;
  }

  .prose :global(strong) {
    font-weight: 800;
    color: var(--coconut);
  }

  .prose :global(img) {
    border-radius: var(--radius-lg);
    border: 1.5px solid var(--border);
    margin-block: 1.5rem;
  }

  /* ── Footer ──────────────────────────── */
  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
</style>
