---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const allProjects = await getCollection("projects");
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<Layout title="Nadia | Portfolio & Blog" description="Welcome to Nadia's personal portfolio and blog.">
  <section>
    <h1>Welcome 👋 I’m Nadia</h1>
    <p>
      I build thoughtful products and share what I learn. This is my personal website where I keep my
      portfolio and write short blog posts.
    </p>
  </section>

  <section>
    <h2>Portfolio</h2>
    <div class="grid">
      {
        projects.map((project) => (
          <article class="card">
            <h3>{project.data.title}</h3>
            <p>{project.data.description}</p>
            <ul class="tags">
              {project.data.tags.map((tag) => (
                <li class="tag">{tag}</li>
              ))}
            </ul>
            <p>
              {project.data.repoUrl && <a href={project.data.repoUrl}>Repository</a>}
              {project.data.repoUrl && project.data.demoUrl && " · "}
              {project.data.demoUrl && <a href={project.data.demoUrl}>Live Demo</a>}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section>
    <h2>Latest Blog Posts</h2>
    <div class="grid">
      {
        posts.map((post) => (
          <article class="card">
            <h3>
              <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
            <small>{post.data.pubDate.toLocaleDateString("en-US", { dateStyle: "medium" })}</small>
          </article>
        ))
      }
    </div>
    <p><a href={`${import.meta.env.BASE_URL}blog`}>Read all posts →</a></p>
  </section>
</Layout>
