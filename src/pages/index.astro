---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const allProjects = await getCollection("projects");
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout title="Nadia | Portfolio & Blog" description="Welcome to Nadia's personal portfolio and blog.">

  <!-- ── Hero ──────────────────────────── -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Open to new projects
      </div>
      <h1 class="hero-title">
        Hi, I'm <mark class="highlight">Nadia</mark> 👋
      </h1>
      <p class="hero-desc">
        Content manager, strategist, and storyteller. I help brands be seen,
        heard, and remembered — through SEO content, copy, and narrative that
        actually connects.
      </p>
      <div class="hero-ctas">
        <a href={`${base}/blog`} class="btn">Read my blog</a>
        <a href="#portfolio" class="btn btn-ghost">View projects</a>
      </div>
    </div>
    <div class="hero-ticker" aria-hidden="true">
      <span>Portfolio</span><span>·</span>
      <span>Blog</span><span>·</span>
      <span>Astro</span><span>·</span>
      <span>GitHub Pages</span><span>·</span>
      <span>Markdown</span><span>·</span>
      <span>Portfolio</span><span>·</span>
      <span>Blog</span><span>·</span>
      <span>Astro</span><span>·</span>
      <span>GitHub Pages</span><span>·</span>
      <span>Markdown</span><span>·</span>
    </div>
  </section>

  <!-- ── Portfolio ─────────────────────── -->
  <section id="portfolio" class="section container">
    <div class="section-head">
      <h2>Portfolio</h2>
      <p class="section-sub">A selection of projects I've been working on.</p>
    </div>
    <div class="grid">
      {
        projects.map((project) => (
          <article class="card project-card">
            <div class="card-body">
              <h3 class="card-title">{project.data.title}</h3>
              <p class="card-desc">{project.data.description}</p>
            </div>
            <footer class="card-footer">
              <ul class="tags">
                {project.data.tags.map((tag) => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
              {(project.data.repoUrl || project.data.demoUrl) && (
                <div class="card-links">
                  {project.data.repoUrl && (
                    <a href={project.data.repoUrl} class="card-link">
                      ↗ Repo
                    </a>
                  )}
                  {project.data.demoUrl && (
                    <a href={project.data.demoUrl} class="card-link">
                      ↗ Demo
                    </a>
                  )}
                </div>
              )}
            </footer>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ── Blog ──────────────────────────── -->
  <section class="section container">
    <div class="section-head">
      <h2>Latest Posts</h2>
      <p class="section-sub">Short notes, updates, and learnings.</p>
    </div>
    <div class="post-list">
      {
        posts.map((post) => (
          <a
            href={`${base}/blog/${post.id}`}
            class="post-row"
          >
            <time class="post-date">
              {post.data.pubDate.toLocaleDateString("en-US", { dateStyle: "medium" })}
            </time>
            <div class="post-center">
              <p class="post-title">{post.data.title}</p>
              <p class="post-desc">{post.data.description}</p>
            </div>
            <span class="post-arrow">→</span>
          </a>
        ))
      }
    </div>
    <div class="view-all">
      <a href={`${base}/blog`} class="btn">All posts →</a>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ──────────────────────────── */
  .hero {
    background: var(--surface);
    border-bottom: 2px solid var(--border);
  }

  .hero-inner {
    padding-top: 4rem;
    padding-bottom: 3rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--cucumber-light);
    color: var(--cucumber);
    font-size: 0.8rem;
    font-weight: 800;
    padding: 0.3rem 0.8rem;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 1.25rem;
  }

  .badge-dot {
    width: 7px;
    height: 7px;
    background: var(--cucumber);
    border-radius: 50%;
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hero-title {
    font-size: clamp(2.6rem, 6.5vw, 4.25rem);
    margin-bottom: 1.1rem;
  }

  .highlight {
    background: var(--banana);
    color: var(--coconut);
    padding: 0.04em 0.18em;
    border-radius: 0.3rem;
    font-style: normal;
  }

  .hero-desc {
    font-size: 1.15rem;
    color: var(--muted);
    max-width: 520px;
    margin-bottom: 2.25rem;
    line-height: 1.75;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* Ticker stripe */
  .hero-ticker {
    display: flex;
    gap: 1.25rem;
    padding: 0.65rem 0;
    background: var(--banana);
    border-top: 2px solid var(--coconut);
    overflow: hidden;
    font-weight: 800;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--coconut);
    white-space: nowrap;
  }

  .hero-ticker span {
    flex-shrink: 0;
    padding-inline: 0.75rem;
  }

  /* ── Sections ──────────────────────── */
  .section-head {
    margin-bottom: 2rem;
  }

  .section-head h2 {
    font-size: 1.85rem;
    margin-bottom: 0.3rem;
  }

  .section-sub {
    color: var(--muted);
    margin: 0;
    font-size: 1rem;
  }

  /* ── Project cards ─────────────────── */
  .project-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .card-body {
    flex: 1;
  }

  .card-title {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }

  .card-desc {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
  }

  .card-footer {
    margin-top: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .card-links {
    display: flex;
    gap: 1rem;
  }

  .card-link {
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--cucumber);
  }

  .card-link:hover {
    color: var(--caramel);
  }

  /* ── Post list ─────────────────────── */
  .post-list {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .post-row {
    display: grid;
    grid-template-columns: 130px 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border);
    color: var(--coconut) !important;
    transition: background var(--ease);
    text-decoration: none !important;
  }

  .post-row:last-child {
    border-bottom: none;
  }

  .post-row:hover {
    background: var(--wheat);
  }

  .post-date {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--muted);
    white-space: nowrap;
  }

  .post-title {
    font-size: 1rem;
    font-weight: 800;
    color: var(--coconut);
    margin: 0 0 0.2rem;
  }

  .post-desc {
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
  }

  .post-arrow {
    font-size: 1.2rem;
    color: var(--muted);
    transition: transform var(--ease), color var(--ease);
  }

  .post-row:hover .post-arrow {
    transform: translateX(4px);
    color: var(--cucumber);
  }

  .view-all {
    margin-top: 1.5rem;
  }

  @media (max-width: 580px) {
    .post-row {
      grid-template-columns: 1fr auto;
    }
    .post-date {
      display: none;
    }
  }
</style>
